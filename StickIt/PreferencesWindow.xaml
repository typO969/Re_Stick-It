<Window
   x:Class="StickIt.PreferencesWindow"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   Title="Preferences"
   Width="640"
   Height="520"
   MinWidth="560"
   MinHeight="480"
   Background="{DynamicResource AppBackgroundBrush}"
   Foreground="{DynamicResource AppForegroundBrush}"
   ShowInTaskbar="False"
   WindowStartupLocation="CenterOwner">
	<Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<TabControl Grid.Row="0">
			<TabItem Header="General">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="10">
						<GroupBox Header="General" Margin="0,0,0,10">
							<StackPanel Margin="10">
								<CheckBox Content="Automatically run StickIt when I log on to Windows" IsChecked="{Binding RunOnStartup}" />
								<CheckBox Content="Dark mode" IsChecked="{Binding DarkMode}" />
								<CheckBox Content="Show StickIt icon on Windows taskbar" IsChecked="{Binding ShowTaskbarIcon}" />
								<CheckBox Content="Show StickIt icon inside system tray (notification area)" IsChecked="{Binding ShowTrayIcon}" />
							</StackPanel>
						</GroupBox>

						<GroupBox Header="Notes">
							<StackPanel Margin="10">
								<CheckBox Content="Always stick new notes to Windows desktop" IsChecked="{Binding AlwaysStickNewNotesToDesktop}" />
								<CheckBox Content="Snap notes to grid" IsChecked="{Binding SnapNotesToGrid}" />

								<StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
									<CheckBox Content="Keep notes inside specific desktop area" IsChecked="{Binding KeepNotesInsideDesktopArea}" VerticalAlignment="Center" />
									<Button Margin="10,0,0,0" MinWidth="110" Content="Desktop area..." Click="DesktopArea_Click" />
								</StackPanel>

								<TextBlock Margin="24,4,0,0" FontSize="11" Foreground="{DynamicResource AppForegroundBrush}" Text="{Binding DesktopAreaSummary}" />

								<CheckBox Margin="0,8,0,0" Content="Show confirmation message when deleting a note" IsChecked="{Binding ConfirmOnDelete}" />
								<CheckBox Content="Hide notes on Show Desktop (Win+D)" IsChecked="{Binding HideNotesOnShowDesktop}" />
								<CheckBox Content="Treat each desktop sticky note as separate top level window" IsChecked="{Binding TreatNotesAsTopLevelWindows}" />
								<CheckBox Content="Keep separate set of notes on each computer's desktop area" IsChecked="{Binding SeparateNotesPerDesktopArea}" />
							</StackPanel>
						</GroupBox>
					</StackPanel>
				</ScrollViewer>
			</TabItem>

			<TabItem Header="Note">
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<StackPanel Margin="10">
						<GroupBox Header="Title &amp; Body (Defaults)" Margin="0,0,0,10">
							<Grid Margin="10">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="120" />
									<ColumnDefinition Width="*" />
									<ColumnDefinition Width="90" />
								</Grid.ColumnDefinitions>

								<TextBlock Grid.Row="0" Text="Title font:" VerticalAlignment="Center" />
								<ComboBox
                           Grid.Row="0"
                           Grid.Column="1"
                           ItemsSource="{Binding FontFamilies}"
                           SelectedItem="{Binding TitleFontFamily}"
                           DisplayMemberPath="Source"
                           Margin="0,0,8,0" />
								<ComboBox
                           Grid.Row="0"
                           Grid.Column="2"
                           ItemsSource="{Binding FontSizes}"
                           SelectedItem="{Binding TitleFontSize}" />

								<TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Body font:" VerticalAlignment="Center" />
								<ComboBox
                           Grid.Row="1"
                           Grid.Column="1"
                           Margin="0,8,8,0"
                           ItemsSource="{Binding FontFamilies}"
                           SelectedItem="{Binding BodyFontFamily}"
                           DisplayMemberPath="Source" />
								<ComboBox
                           Grid.Row="1"
                           Grid.Column="2"
                           Margin="0,8,0,0"
                           ItemsSource="{Binding FontSizes}"
                           SelectedItem="{Binding BodyFontSize}" />

								<CheckBox
                           Grid.Row="2"
                           Grid.Column="0"
                           Grid.ColumnSpan="3"
                           Margin="0,10,0,0"
                           Content="Show date along with note title"
                           IsChecked="{Binding ShowDateAlongTitle}" />
							</Grid>
						</GroupBox>

						<GroupBox Header="Appearance">
							<StackPanel Margin="10">
								<CheckBox Content="Enable drop shadow" IsChecked="{Binding EnableDropShadow}" />
							</StackPanel>
						</GroupBox>
					</StackPanel>
				</ScrollViewer>
			</TabItem>
		</TabControl>

		<StackPanel Grid.Row="1" Margin="0,10,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
			<Button MinWidth="90" Click="Ok_Click" Content="OK" IsDefault="True" BorderBrush="#FF1C1C1C" Width="112" FontWeight="Bold" FontSize="14" FontFamily="Helvetica" BorderThickness="2,2,2,2" />
			<Button MinWidth="60" Margin="0,0,8,0" Click="Cancel_Click" Content="Cancel" Width="52" FontFamily="Helvetica" FontStyle="Italic" />
		</StackPanel>
	</Grid>
</Window>
