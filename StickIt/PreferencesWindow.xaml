<Window
   x:Class="StickIt.PreferencesWindow"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   Title="Preferences"
   Width="765"
   Height="543"
   MinWidth="560"
   MinHeight="480"
   Background="{DynamicResource AppBackgroundBrush}"
   Foreground="{DynamicResource AppForegroundBrush}"
   ShowInTaskbar="False"
   WindowStartupLocation="CenterScreen">
   <Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
      <Grid.RowDefinitions>
         <RowDefinition Height="*" />
         <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TabControl Grid.Row="0">
         <TabItem Header="General">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
               <StackPanel Margin="10">
                  <GroupBox Margin="0,0,0,10" Header="General">
                     <StackPanel Margin="10">
                        <CheckBox Content="Automatically run StickIt when I log on to Windows" IsChecked="{Binding RunOnStartup}" />
                        <CheckBox Content="Dark mode" IsChecked="{Binding DarkMode}" />
                        <CheckBox Content="Show note's icons on taskbar" IsChecked="{Binding ShowTaskbarIcon}" />
                        <CheckBox Content="Show StickIt icon inside system tray (notification area)" IsChecked="{Binding ShowTrayIcon}" />
                     </StackPanel>
                  </GroupBox>

                  <GroupBox Header="Notes">
                     <StackPanel Margin="10">
                        <CheckBox Content="Always stick new notes to Windows desktop" IsChecked="{Binding AlwaysStickNewNotesToDesktop}" />
                        <CheckBox Content="Snap notes to grid" IsChecked="{Binding SnapNotesToGrid}" />

                        <StackPanel
                           Margin="0,6,0,0"
                           VerticalAlignment="Center"
                           Orientation="Horizontal">
                           <CheckBox
                              VerticalAlignment="Center"
                              Content="Keep notes inside specific desktop area"
                              IsChecked="{Binding KeepNotesInsideDesktopArea}" />
                           <Button
                              MinWidth="110"
                              Margin="10,0,0,0"
                              Click="DesktopArea_Click"
                              Content="Desktop area..." />
                        </StackPanel>

                        <TextBlock
                           Margin="24,4,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           Text="{Binding DesktopAreaSummary}" />

                        <CheckBox
                           Margin="0,8,0,0"
                           Content="Show confirmation message when deleting a note"
                           IsChecked="{Binding ConfirmOnDelete}" />
                        <CheckBox Content="Hide notes on Show Desktop (Win+D)" IsChecked="{Binding HideNotesOnShowDesktop}" />
                        <CheckBox Content="Treat each desktop sticky note as separate top level window" IsChecked="{Binding TreatNotesAsTopLevelWindows}" />

                        <TextBlock
                           Margin="0,10,0,2"
                           FontWeight="SemiBold"
                           Text="Stick to Window (Mode 2)" />
                        <CheckBox Content="In mode 2, prevent moving note unless Lift is active" IsChecked="{Binding Mode2PreventManualMove}" />
                        <CheckBox Content="In mode 2, minimize note when host is minimized" IsChecked="{Binding Mode2MinimizeWithHost}" />
                        <CheckBox Content="Close note when host window closes in mode 2" IsChecked="{Binding Mode2CloseNoteWhenHostCloses}" />

                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                           <TextBlock
                              Width="294"
                              VerticalAlignment="Center"
                              Text="If host/parent window becomes missing in mode 2:" />
                           <ComboBox
                              Width="235"
                              DisplayMemberPath="Label"
                              ItemsSource="{Binding Mode2HostMissingActions}"
                              SelectedItem="{Binding SelectedMode2HostMissingAction}" />
                        </StackPanel>
                     </StackPanel>
                  </GroupBox>
               </StackPanel>
            </ScrollViewer>
         </TabItem>

         <TabItem Header="Note">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
               <StackPanel Margin="10">
                  <GroupBox Margin="0,0,0,10" Header="Title &amp; Body (Defaults)">
                     <Grid Margin="10">
                        <Grid.RowDefinitions>
                           <RowDefinition Height="Auto" />
                           <RowDefinition Height="Auto" />
                           <RowDefinition Height="Auto" />
                           <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                           <ColumnDefinition Width="120" />
                           <ColumnDefinition Width="*" />
                           <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                           Grid.Row="0"
                           VerticalAlignment="Center"
                           Text="Title font:" />
                        <ComboBox
                           Grid.Row="0"
                           Grid.Column="1"
                           Margin="0,0,8,0"
                           DisplayMemberPath="Source"
                           ItemsSource="{Binding FontFamilies}"
                           SelectedItem="{Binding TitleFontFamily}" />
                        <ComboBox
                           Grid.Row="0"
                           Grid.Column="2"
                           ItemsSource="{Binding FontSizes}"
                           SelectedItem="{Binding TitleFontSize}" />

                        <CheckBox
                           Grid.Row="1"
                           Grid.Column="1"
                           Margin="0,8,0,0"
                           Content="Title is bold"
                           IsChecked="{Binding TitleFontBold}" />

                        <TextBlock
                           Grid.Row="2"
                           Margin="0,8,0,0"
                           VerticalAlignment="Center"
                           Text="Body font:" />
                        <ComboBox
                           Grid.Row="2"
                           Grid.Column="1"
                           Margin="0,8,8,0"
                           DisplayMemberPath="Source"
                           ItemsSource="{Binding FontFamilies}"
                           SelectedItem="{Binding BodyFontFamily}" />
                        <ComboBox
                           Grid.Row="2"
                           Grid.Column="2"
                           Margin="0,8,0,0"
                           ItemsSource="{Binding FontSizes}"
                           SelectedItem="{Binding BodyFontSize}" />

                        <CheckBox
                           Grid.Row="3"
                           Grid.Column="0"
                           Grid.ColumnSpan="3"
                           Margin="0,10,0,0"
                           Content="Show date along with note title"
                           IsChecked="{Binding ShowDateAlongTitle}" />
                     </Grid>
                  </GroupBox>

                  <GroupBox Header="Appearance">
                     <StackPanel Margin="10">
                        <CheckBox Content="Enable drop shadow" IsChecked="{Binding EnableDropShadow}" />
                        <CheckBox Content="Enable note borders" IsChecked="{Binding EnableNoteBorders}" />
                     </StackPanel>
                  </GroupBox>
               </StackPanel>
            </ScrollViewer>
         </TabItem>
         <TabItem Header="Sync">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
               <StackPanel Margin="10">
                  <GroupBox Header="Sync (Manual)">
                     <StackPanel Margin="10">
                        <CheckBox Content="Enable sync" IsChecked="{Binding SyncEnabled}" />
                        <CheckBox
                           Margin="0,6,0,0"
                           Content="Sync preferences across devices"
                           IsChecked="{Binding SyncPreferences}" />

                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                           <TextBlock
                              Width="135"
                              VerticalAlignment="Center"
                              Text="Sync behavior:" />
                           <ComboBox
                              Width="390"
                              DisplayMemberPath="Label"
                              ItemsSource="{Binding SyncModes}"
                              SelectedItem="{Binding SelectedSyncMode}" />
                        </StackPanel>

                        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                           <TextBlock
                              Width="135"
                              VerticalAlignment="Center"
                              Text="When pulling:" />
                           <ComboBox
                              Width="390"
                              DisplayMemberPath="Label"
                              ItemsSource="{Binding SyncImportModes}"
                              SelectedItem="{Binding SelectedSyncImportMode}" />
                        </StackPanel>

                        <TextBlock
                           Margin="0,10,0,2"
                           FontWeight="SemiBold"
                           Text="Sync file" />
                        <Grid>
                           <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                           </Grid.ColumnDefinitions>
                           <TextBox
                              Grid.Column="0"
                              Margin="0,0,8,0"
                              Text="{Binding SyncFilePath, UpdateSourceTrigger=PropertyChanged}" />
                           <Button
                              Grid.Column="1"
                              Click="BrowseSyncFile_Click"
                              Content="Browse..." />
                        </Grid>

                        <TextBlock
                           Margin="0,8,0,0"
                           FontSize="11"
                           Text="Manual sync only: StickIt syncs when you click Sync now." />

                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                           <Button
                              MinWidth="95"
                              Click="SyncNow_Click"
                              Content="Sync now" />
                           <Button
                              MinWidth="95"
                              Margin="8,0,0,0"
                              Click="PullSync_Click"
                              Content="Pull" />
                           <Button
                              MinWidth="95"
                              Margin="8,0,0,0"
                              Click="PushSync_Click"
                              Content="Push" />
                           <TextBlock
                              Margin="10,2,0,0"
                              VerticalAlignment="Center"
                              Text="Last sync:" />
                           <TextBlock
                              Margin="6,2,0,0"
                              VerticalAlignment="Center"
                              FontWeight="SemiBold"
                              Text="{Binding LastSyncSummary}" />
                        </StackPanel>
                     </StackPanel>
                  </GroupBox>
               </StackPanel>
            </ScrollViewer>
         </TabItem>
      </TabControl>

      <StackPanel
         Grid.Row="1"
         Margin="0,10,0,0"
         HorizontalAlignment="Right"
         Orientation="Horizontal">
         <Button
            Width="52"
            MinWidth="60"
            Margin="0,0,8,0"
            Click="Cancel_Click"
            Content="Cancel"
            FontFamily="Helvetica"
            FontStyle="Italic" />
         <Button
            Width="112"
            MinWidth="90"
            BorderBrush="#FF1C1C1C"
            BorderThickness="2,2,2,2"
            Click="Ok_Click"
            Content="OK"
            FontFamily="Helvetica"
            FontSize="14"
            FontWeight="Bold"
            IsDefault="True" />
      </StackPanel>
   </Grid>
</Window>
