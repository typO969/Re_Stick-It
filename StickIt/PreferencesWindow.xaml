<Window
   x:Class="StickIt.PreferencesWindow"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   Title="Preferences"
   Width="640"
   Height="520"
   MinWidth="560"
   MinHeight="480"
   Background="{DynamicResource AppBackgroundBrush}"
   Foreground="{DynamicResource AppForegroundBrush}"
   ShowInTaskbar="False"
   WindowStartupLocation="CenterOwner">
   <Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
      <Grid.RowDefinitions>
         <RowDefinition Height="*" />
         <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TabControl Grid.Row="0">
         <TabItem Header="General">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
               <StackPanel Margin="10">
                  <GroupBox Margin="0,0,0,10" Header="General">
                     <StackPanel Margin="10">
                        <CheckBox Content="Automatically run StickIt when I log on to Windows" IsChecked="{Binding RunOnStartup}" />
                        <CheckBox Content="Dark mode" IsChecked="{Binding DarkMode}" />
                        <CheckBox Content="Show StickIt icon on Windows taskbar" IsChecked="{Binding ShowTaskbarIcon}" />
                        <CheckBox Content="Show StickIt icon inside system tray (notification area)" IsChecked="{Binding ShowTrayIcon}" />
                     </StackPanel>
                  </GroupBox>

                  <GroupBox Header="Notes">
                     <StackPanel Margin="10">
                        <CheckBox Content="Always stick new notes to Windows desktop" IsChecked="{Binding AlwaysStickNewNotesToDesktop}" />
                        <CheckBox Content="Snap notes to grid" IsChecked="{Binding SnapNotesToGrid}" />

                        <StackPanel
                           Margin="0,6,0,0"
                           VerticalAlignment="Center"
                           Orientation="Horizontal">
                           <CheckBox
                              VerticalAlignment="Center"
                              Content="Keep notes inside specific desktop area"
                              IsChecked="{Binding KeepNotesInsideDesktopArea}" />
                           <Button
                              MinWidth="110"
                              Margin="10,0,0,0"
                              Click="DesktopArea_Click"
                              Content="Desktop area..." />
                        </StackPanel>

                        <TextBlock
                           Margin="24,4,0,0"
                           FontSize="11"
                           Foreground="{DynamicResource AppForegroundBrush}"
                           Text="{Binding DesktopAreaSummary}" />

                        <CheckBox
                           Margin="0,8,0,0"
                           Content="Show confirmation message when deleting a note"
                           IsChecked="{Binding ConfirmOnDelete}" />
                        <CheckBox Content="Hide notes on Show Desktop (Win+D)" IsChecked="{Binding HideNotesOnShowDesktop}" />
                        <CheckBox Content="Treat each desktop sticky note as separate top level window" IsChecked="{Binding TreatNotesAsTopLevelWindows}" />
                        <CheckBox Content="Keep separate set of notes on each computer's desktop area" IsChecked="{Binding SeparateNotesPerDesktopArea}" />
                     </StackPanel>
                  </GroupBox>
               </StackPanel>
            </ScrollViewer>
         </TabItem>

         <TabItem Header="Note">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
               <StackPanel Margin="10">
                  <GroupBox Margin="0,0,0,10" Header="Title &amp; Body (Defaults)">
                     <Grid Margin="10">
                        <Grid.RowDefinitions>
                           <RowDefinition Height="Auto" />
                           <RowDefinition Height="Auto" />
                           <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                           <ColumnDefinition Width="120" />
                           <ColumnDefinition Width="*" />
                           <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                           Grid.Row="0"
                           VerticalAlignment="Center"
                           Text="Title font:" />
                        <ComboBox
                           Grid.Row="0"
                           Grid.Column="1"
                           Margin="0,0,8,0"
                           DisplayMemberPath="Source"
                           ItemsSource="{Binding FontFamilies}"
                           SelectedItem="{Binding TitleFontFamily}" />
                        <ComboBox
                           Grid.Row="0"
                           Grid.Column="2"
                           ItemsSource="{Binding FontSizes}"
                           SelectedItem="{Binding TitleFontSize}" />

                        <TextBlock
                           Grid.Row="1"
                           Margin="0,8,0,0"
                           VerticalAlignment="Center"
                           Text="Body font:" />
                        <ComboBox
                           Grid.Row="1"
                           Grid.Column="1"
                           Margin="0,8,8,0"
                           DisplayMemberPath="Source"
                           ItemsSource="{Binding FontFamilies}"
                           SelectedItem="{Binding BodyFontFamily}" />
                        <ComboBox
                           Grid.Row="1"
                           Grid.Column="2"
                           Margin="0,8,0,0"
                           ItemsSource="{Binding FontSizes}"
                           SelectedItem="{Binding BodyFontSize}" />

                        <CheckBox
                           Grid.Row="2"
                           Grid.Column="0"
                           Grid.ColumnSpan="3"
                           Margin="0,10,0,0"
                           Content="Show date along with note title"
                           IsChecked="{Binding ShowDateAlongTitle}" />
                     </Grid>
                  </GroupBox>

                  <GroupBox Header="Appearance">
                     <StackPanel Margin="10">
                        <CheckBox Content="Enable drop shadow" IsChecked="{Binding EnableDropShadow}" />
                     </StackPanel>
                  </GroupBox>
               </StackPanel>
            </ScrollViewer>
         </TabItem>

         <TabItem Header="Skins">
            <Grid Margin="10">
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="240" />
                  <ColumnDefinition Width="12" />
                  <ColumnDefinition Width="*" />
               </Grid.ColumnDefinitions>
               <Grid.RowDefinitions>
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
               </Grid.RowDefinitions>

               <ListBox
                  Grid.Row="0"
                  Grid.Column="0"
                  DisplayMemberPath="DisplayName"
                  ItemsSource="{Binding SkinLibrary}"
                  SelectedItem="{Binding SelectedSkin}" />

               <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Orientation="Horizontal">
                  <Button MinWidth="70" Margin="0,0,8,0" Click="SkinNew_Click" Content="New" />
                  <Button MinWidth="80" Margin="0,0,8,0" Click="SkinDuplicate_Click" Content="Duplicate" />
                  <Button MinWidth="70" Click="SkinDelete_Click" Content="Delete" />
               </StackPanel>

               <GroupBox Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Header="Skin details">
                  <Grid Margin="10">
                     <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                     </Grid.RowDefinitions>
                     <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                     </Grid.ColumnDefinitions>

                     <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Id:" />
                     <TextBox Grid.Row="0" Grid.Column="1" IsReadOnly="True" Text="{Binding SelectedSkin.Id}" />

                     <TextBlock Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center" Text="Name:" />
                     <TextBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" IsEnabled="{Binding SelectedSkinIsEditable}" Text="{Binding SelectedSkin.Name, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="2" Margin="0,8,0,0" VerticalAlignment="Center" Text="Paper hex:" />
                     <TextBox Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" IsEnabled="{Binding SelectedSkinIsEditable}" Text="{Binding SelectedSkin.PaperHex, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="3" Margin="0,8,0,0" VerticalAlignment="Center" Text="Control bar hex:" />
                     <TextBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" IsEnabled="{Binding SelectedSkinIsEditable}" Text="{Binding SelectedSkin.ControlBarHex, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="4" Margin="0,8,0,0" VerticalAlignment="Center" Text="Button hex:" />
                     <TextBox Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" IsEnabled="{Binding SelectedSkinIsEditable}" Text="{Binding SelectedSkin.ButtonHex, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="5" Margin="0,8,0,0" VerticalAlignment="Center" Text="Text hex:" />
                     <TextBox Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" IsEnabled="{Binding SelectedSkinIsEditable}" Text="{Binding SelectedSkin.TextHex, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="6" Margin="0,8,0,0" VerticalAlignment="Center" Text="Highlight hex:" />
                     <TextBox Grid.Row="6" Grid.Column="1" Margin="0,8,0,0" IsEnabled="{Binding SelectedSkinIsEditable}" Text="{Binding SelectedSkin.HighlightHex, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="7" Margin="0,8,0,0" VerticalAlignment="Center" Text="Outline hex:" />
                     <TextBox Grid.Row="7" Grid.Column="1" Margin="0,8,0,0" IsEnabled="{Binding SelectedSkinIsEditable}" Text="{Binding SelectedSkin.OutlineHex, UpdateSourceTrigger=PropertyChanged}" />

                     <TextBlock Grid.Row="8" Margin="0,8,0,0" VerticalAlignment="Center" Text="Paper image:" />
                     <StackPanel Grid.Row="8" Grid.Column="1" Margin="0,8,0,0" Orientation="Horizontal">
                        <TextBox Width="220" IsEnabled="{Binding SelectedSkinIsEditable}" Text="{Binding SelectedSkin.PaperImagePath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button MinWidth="60" Margin="8,0,0,0" Click="SkinBrowseImage_Click" Content="Browse" />
                     </StackPanel>
                  </Grid>
               </GroupBox>
            </Grid>
         </TabItem>
      </TabControl>

      <StackPanel
         Grid.Row="1"
         Margin="0,10,0,0"
         HorizontalAlignment="Right"
         Orientation="Horizontal">
         <Button
            Width="52"
            MinWidth="60"
            Margin="0,0,8,0"
            Click="Cancel_Click"
            Content="Cancel"
            FontFamily="Helvetica"
            FontStyle="Italic" />
         <Button
            Width="112"
            MinWidth="90"
            BorderBrush="#FF1C1C1C"
            BorderThickness="2,2,2,2"
            Click="Ok_Click"
            Content="OK"
            FontFamily="Helvetica"
            FontSize="14"
            FontWeight="Bold"
            IsDefault="True" />
      </StackPanel>
   </Grid>
</Window>
