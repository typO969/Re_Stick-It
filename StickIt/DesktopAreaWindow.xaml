<Window
   x:Class="StickIt.DesktopAreaWindow"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   Title="Desktop area"
   Width="360"
   Height="240"
   ResizeMode="NoResize"
   Background="{DynamicResource AppBackgroundBrush}"
   Foreground="{DynamicResource AppForegroundBrush}"
   ShowInTaskbar="False"
   WindowStartupLocation="CenterOwner">
   <Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
      <Grid.RowDefinitions>
         <RowDefinition Height="*" />
         <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
         </Grid.RowDefinitions>
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
         </Grid.ColumnDefinitions>

         <TextBlock Grid.Row="0" Text="Left:" VerticalAlignment="Center" />
         <TextBox x:Name="LeftBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" />

         <TextBlock Grid.Row="1" Text="Top:" VerticalAlignment="Center" />
         <TextBox x:Name="TopBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" />

         <TextBlock Grid.Row="2" Text="Width:" VerticalAlignment="Center" />
         <TextBox x:Name="WidthBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" />

         <TextBlock Grid.Row="3" Text="Height:" VerticalAlignment="Center" />
         <TextBox x:Name="HeightBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,6" />

         <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Padding="8,2" Margin="0,0,8,0" Content="Use virtual desktop" Click="UseVirtualDesktop_Click" />
            <Button Padding="8,2" Content="Pick on screen..." Click="PickOnScreen_Click" />
         </StackPanel>
      </Grid>

      <StackPanel Grid.Row="1" Margin="0,10,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
         <Button MinWidth="80" Margin="0,0,8,0" Content="Cancel" Click="Cancel_Click" />
         <Button MinWidth="80" Content="OK" IsDefault="True" Click="Ok_Click" />
      </StackPanel>
   </Grid>
</Window>
