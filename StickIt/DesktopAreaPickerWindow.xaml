<Window
   x:Class="StickIt.DesktopAreaPickerWindow"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   WindowStyle="None"
   AllowsTransparency="True"
   Background="#40000000"
   ShowInTaskbar="False"
   Topmost="True"
   ResizeMode="NoResize"
   Cursor="Cross">
   <Canvas x:Name="SelectionCanvas" Background="Transparent" MouseLeftButtonDown="Canvas_MouseLeftButtonDown" MouseMove="Canvas_MouseMove" MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
      <Rectangle
         x:Name="SelectionRect"
         Stroke="#FF00C8FF"
         StrokeThickness="2"
         Fill="#2000C8FF"
         Visibility="Collapsed" />
   </Canvas>
</Window>
