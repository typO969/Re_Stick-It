<Application
	x:Class="StickIt.App"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	ShutdownMode="OnLastWindowClose">

	<Application.Resources>
		<SolidColorBrush x:Key="AppBackgroundBrush" Color="#FAFAFA" />
		<SolidColorBrush x:Key="AppForegroundBrush" Color="#1E1E1E" />
		<SolidColorBrush x:Key="AppPanelBrush" Color="#F0F0F0" />
		<SolidColorBrush x:Key="AppBorderBrush" Color="#C8C8C8" />

		<DropShadowEffect
			x:Key="DropShadow"
			BlurRadius="10"
			Opacity="0.18"
			ShadowDepth="1"
			Color="Black" />
	</Application.Resources>

</Application>
