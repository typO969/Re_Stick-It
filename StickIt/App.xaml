<Application
	x:Class="StickIt.App"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	ShutdownMode="OnLastWindowClose">

	<Application.Resources>
		<DropShadowEffect
			x:Key="DropShadow"
			BlurRadius="10"
			Opacity="0.18"
			ShadowDepth="1"
			Color="Black" />
	</Application.Resources>

</Application>
