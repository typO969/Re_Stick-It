<Window
   x:Class="StickIt.NoteManagerWindow"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   Title="Note manager"
   Width="760"
   Height="460"
   MinWidth="640"
   MinHeight="360"
   Background="{DynamicResource AppBackgroundBrush}"
   Foreground="{DynamicResource AppForegroundBrush}"
   ShowInTaskbar="False"
   WindowStartupLocation="CenterOwner">
   <Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto" />
         <RowDefinition Height="*" />
         <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock
         Margin="0,0,0,10"
         FontSize="16"
         FontWeight="SemiBold"
         Text="Note manager" />

      <DataGrid
         x:Name="NotesGrid"
         Grid.Row="1"
         Background="{DynamicResource AppPanelBrush}"
         BorderBrush="{DynamicResource AppBorderBrush}"
         Foreground="{DynamicResource AppForegroundBrush}"
         AutoGenerateColumns="False"
         CanUserAddRows="False"
         CanUserDeleteRows="False"
         IsReadOnly="True"
         SelectionMode="Single">
         <DataGrid.Columns>
            <DataGridTextColumn Width="2*" Binding="{Binding Title}" Header="Title" />
            <DataGridTextColumn Width="*" Binding="{Binding Color}" Header="Color" />
            <DataGridTextColumn Width="*" Binding="{Binding Sticky}" Header="Sticky" />
            <DataGridTextColumn Width="*" Binding="{Binding Modified}" Header="Modified" />
            <DataGridTextColumn Width="*" Binding="{Binding IsMinimized}" Header="Minimized" />
            <DataGridTemplateColumn Width="Auto" Header="Actions">
               <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                     <StackPanel Orientation="Horizontal">
                        <Button Margin="0,0,6,0" Padding="6,2" Content="Show" Tag="{Binding Window}" Click="Show_Click" />
                        <Button Margin="0,0,6,0" Padding="6,2" Content="Minimize" Tag="{Binding Window}" Click="Minimize_Click" />
                        <Button Margin="0,0,6,0" Padding="6,2" Content="Restore" Tag="{Binding Window}" Click="Restore_Click" />
                        <Button Padding="6,2" Content="Close" Tag="{Binding Window}" Click="Close_Click" />
                     </StackPanel>
                  </DataTemplate>
               </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
         </DataGrid.Columns>
      </DataGrid>

      <StackPanel Grid.Row="2" Margin="0,10,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
         <Button MinWidth="90" Margin="0,0,8,0" Click="Refresh_Click" Content="Refresh" />
         <Button MinWidth="90" Click="Done_Click" Content="Done" IsDefault="True" />
      </StackPanel>
   </Grid>
</Window>
