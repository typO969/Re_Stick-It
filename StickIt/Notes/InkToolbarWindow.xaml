<Window
   x:Class="StickIt.InkToolbarWindow"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   SizeToContent="WidthAndHeight"
   AllowsTransparency="True"
   Background="Transparent"
   ResizeMode="NoResize"
   ShowInTaskbar="False"
   Topmost="False"
   WindowStyle="None">
   <Border
      Background="#FFF9F0A6"
      BorderBrush="#99000000"
      BorderThickness="1"
      CornerRadius="6"
      MouseLeftButtonDown="Root_MouseLeftButtonDown">
      <Grid Margin="4">
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
         </Grid.RowDefinitions>

         <StackPanel Orientation="Horizontal">
            <Button
               x:Name="btnPen"
               MinWidth="44"
               Margin="0,0,4,0"
               Click="Pen_Click"
               Content="Pen"
               Padding="6,2" />
            <Button
               x:Name="btnErase"
               MinWidth="52"
               Margin="0,0,4,0"
               Click="Erase_Click"
               Content="Erase"
               Padding="6,2" />
            <Button
               MinWidth="50"
               Margin="0,0,4,0"
               Click="Clear_Click"
               Content="Clear"
               Padding="6,2" />
            <Button
               MinWidth="48"
               Margin="0,0,4,0"
               Click="Done_Click"
               Content="Done"
               Padding="6,2" />
            <Button
               MinWidth="74"
               Click="Color_Click"
               Content="Color..."
               Padding="6,2" />
            <Border
               x:Name="ColorSwatch"
               Width="16"
               Height="16"
               Margin="6,0,0,0"
               VerticalAlignment="Center"
               Background="Black"
               BorderBrush="#66000000"
               BorderThickness="1"
               CornerRadius="2" />
         </StackPanel>

         <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="Auto" />
               <ColumnDefinition Width="150" />
               <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Text="Thickness:" />
            <Slider
               x:Name="sldThickness"
               Grid.Column="1"
               Margin="8,0,8,0"
               Maximum="10"
               Minimum="1"
               SmallChange="1"
               TickFrequency="1"
               Value="1"
               ValueChanged="sldThickness_ValueChanged"
               IsSnapToTickEnabled="True" />
            <TextBox
               x:Name="txtThickness"
               Grid.Column="2"
               Width="38"
               HorizontalContentAlignment="Center"
               LostFocus="txtThickness_LostFocus"
               Text="1" />
         </Grid>
      </Grid>
   </Border>
</Window>
