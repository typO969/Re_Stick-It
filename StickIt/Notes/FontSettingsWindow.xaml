<Window
   x:Class="StickIt.FontSettingsWindow"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   Title="Font settings"
   Width="520"
   Height="420"
   MinWidth="480"
   MinHeight="380"
   Background="{DynamicResource AppBackgroundBrush}"
   Foreground="{DynamicResource AppForegroundBrush}"
   ShowInTaskbar="False"
   WindowStartupLocation="CenterOwner">
   <Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto" />
         <RowDefinition Height="*" />
         <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock
         Margin="0,0,0,10"
         FontSize="16"
         FontWeight="SemiBold"
         Text="Font settings" />

      <StackPanel Grid.Row="1">
         <GroupBox Header="Font" Margin="0,0,0,10">
            <Grid Margin="10">
               <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
               </Grid.RowDefinitions>
               <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="90" />
               </Grid.ColumnDefinitions>

               <TextBlock Grid.Row="0" Text="Family:" VerticalAlignment="Center" />
               <ComboBox
                  Grid.Row="0"
                  Grid.Column="1"
                  Margin="0,0,8,0"
                  ItemsSource="{Binding FontFamilies}"
                  SelectedItem="{Binding FontFamily}"
                  DisplayMemberPath="Source" />
               <ComboBox
                  Grid.Row="0"
                  Grid.Column="2"
                  ItemsSource="{Binding FontSizes}"
                  SelectedItem="{Binding FontSize}" />

               <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Style:" VerticalAlignment="Center" />
               <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" Orientation="Horizontal">
                  <CheckBox Content="Bold" IsChecked="{Binding IsBold}" Margin="0,0,12,0" />
                  <CheckBox Content="Italic" IsChecked="{Binding IsItalic}" Margin="0,0,12,0" />
                  <CheckBox Content="Underline" IsChecked="{Binding IsUnderline}" />
               </StackPanel>

               <TextBlock Grid.Row="2" Margin="0,8,0,0" Text="Color:" VerticalAlignment="Center" />
               <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,0" ItemsSource="{Binding Colors}" SelectedItem="{Binding SelectedColor}">
                  <ComboBox.ItemTemplate>
                     <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                           <Border Width="14" Height="14" Margin="0,0,6,0" Background="{Binding Brush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" />
                           <TextBlock Text="{Binding Name}" />
                        </StackPanel>
                     </DataTemplate>
                  </ComboBox.ItemTemplate>
               </ComboBox>
            </Grid>
         </GroupBox>

         <GroupBox Header="Apply" Margin="0,0,0,10">
            <StackPanel Margin="10">
               <RadioButton Content="Apply to selection" IsChecked="{Binding ApplyToSelection}" />
               <RadioButton Content="Set as defaults for this note" IsChecked="{Binding ApplyToDefaults}" />
            </StackPanel>
         </GroupBox>

         <GroupBox Header="Preview">
            <Border Margin="10" Padding="10" Background="{DynamicResource AppPanelBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
               <TextBlock
                  Text="The quick brown fox jumps over the lazy dog."
                  FontFamily="{Binding FontFamily}"
                  FontSize="{Binding FontSize}"
                  FontWeight="{Binding PreviewFontWeight}"
                  FontStyle="{Binding PreviewFontStyle}"
                  TextDecorations="{Binding PreviewTextDecorations}"
                  Foreground="{Binding SelectedColor.Brush}" />
            </Border>
         </GroupBox>
      </StackPanel>

      <StackPanel Grid.Row="2" Margin="0,10,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
         <Button MinWidth="90" Margin="0,0,8,0" Click="Cancel_Click" Content="Cancel" />
         <Button MinWidth="90" Click="Ok_Click" Content="OK" IsDefault="True" />
      </StackPanel>
   </Grid>
</Window>
