<Window
   x:Class="StickIt.NotePropertiesWindow"
   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   Title="Note properties"
   Width="420"
   Height="420"
   Background="{DynamicResource AppBackgroundBrush}"
   Foreground="{DynamicResource AppForegroundBrush}"
   ResizeMode="NoResize"
   ShowInTaskbar="False"
   WindowStartupLocation="CenterOwner">
   <Grid Margin="12" Background="{DynamicResource AppBackgroundBrush}">
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto" />
         <RowDefinition Height="*" />
         <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock
         Margin="0,0,0,10"
         FontSize="16"
         FontWeight="SemiBold"
         Text="{Binding NoteTitle}" />

      <Grid Grid.Row="1">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150" />
            <ColumnDefinition Width="*" />
         </Grid.ColumnDefinitions>
         <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
         </Grid.RowDefinitions>

         <TextBlock Grid.Row="0" Text="Note ID:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NoteId}" TextWrapping="Wrap" />

         <TextBlock Grid.Row="1" Margin="0,6,0,0" Text="Contains:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding Contains}" TextWrapping="Wrap" />

         <TextBlock Grid.Row="2" Margin="0,6,0,0" Text="Created:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding CreatedUtc}" />

         <TextBlock Grid.Row="3" Margin="0,6,0,0" Text="Modified:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" Text="{Binding ModifiedUtc}" />

         <TextBlock Grid.Row="4" Margin="0,6,0,0" Text="Position:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" Text="{Binding Position}" />

         <TextBlock Grid.Row="5" Margin="0,6,0,0" Text="Size:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,6,0,0" Text="{Binding Size}" />

         <TextBlock Grid.Row="6" Margin="0,6,0,0" Text="Color:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,6,0,0" Text="{Binding Color}" />

         <TextBlock Grid.Row="7" Margin="0,6,0,0" Text="Sticky:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,6,0,0" Text="{Binding Sticky}" TextWrapping="Wrap" />

         <TextBlock Grid.Row="8" Margin="0,6,0,0" Text="Sticky target:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="8" Grid.Column="1" Margin="0,6,0,0" Text="{Binding StickyTarget}" TextWrapping="Wrap" />

         <TextBlock Grid.Row="9" Margin="0,6,0,0" Text="Font:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="9" Grid.Column="1" Margin="0,6,0,0" Text="{Binding Font}" TextWrapping="Wrap" />

         <TextBlock Grid.Row="10" Margin="0,6,0,0" Text="Monitor:" FontWeight="SemiBold" />
         <TextBlock Grid.Row="10" Grid.Column="1" Margin="0,6,0,0" Text="{Binding Monitor}" TextWrapping="Wrap" />
      </Grid>

      <StackPanel Grid.Row="2" Margin="0,12,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
         <Button MinWidth="90" Click="Close_Click" Content="Close" IsDefault="True" />
      </StackPanel>
   </Grid>
</Window>
