<Window
	x:Class="StickIt.Sticky.StickyTargetPickerWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Title="Stick to Window"
	Width="700"
	Height="420"
	ResizeMode="CanResize"
	ShowInTaskbar="False"
	WindowStartupLocation="CenterOwner">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<TextBlock
			Grid.Row="0"
			Margin="0,0,0,8"
			Text="Pick a window to associate with this note (groundwork only)." />

		<ListView
			x:Name="lv"
			Grid.Row="1"
			Margin="0,0,0,10"
			MouseDoubleClick="lv_MouseDoubleClick"
			SelectionMode="Single">
			<ListView.View>
				<GridView>
					<GridViewColumn
						Width="360"
						DisplayMemberBinding="{Binding WindowTitle}"
						Header="Title" />
					<GridViewColumn
						Width="140"
						DisplayMemberBinding="{Binding ProcessName}"
						Header="Process" />
					<GridViewColumn
						Width="70"
						DisplayMemberBinding="{Binding ProcessId}"
						Header="PID" />
					<GridViewColumn
						Width="120"
						DisplayMemberBinding="{Binding ClassName}"
						Header="Class" />
				</GridView>
			</ListView.View>
		</ListView>

		<StackPanel
			Grid.Row="2"
			HorizontalAlignment="Right"
			Orientation="Horizontal">
			<Button
				MinWidth="90"
				Margin="0,0,8,0"
				Click="btnRefresh_Click"
				Content="Refresh" />
			<Button
				MinWidth="90"
				Margin="0,0,8,0"
				Click="btnSelect_Click"
				Content="Select" />
			<Button
				MinWidth="90"
				Content="Cancel"
				IsCancel="True" />
		</StackPanel>
	</Grid>
</Window>
