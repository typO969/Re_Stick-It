<Window
	x:Class="StickIt.NoteWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Width="300"
	Height="300"
	MinWidth="300"
	MinHeight="300"
	MaxWidth="300"
	MaxHeight="300"
	AllowsTransparency="True"
	Background="Transparent"
	ResizeMode="NoResize"
	UseLayoutRounding="False"
	WindowStyle="None">
	<Border
		Padding="10"
		Background="{Binding PaperBrush}"
		CornerRadius="1.25"
		Effect="{DynamicResource DropShadow}">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="28" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<Grid x:Name="TitleBar" Grid.Row="0">
				<TextBox
					Background="Transparent"
					BorderThickness="0"
					FontWeight="Bold"
					Text="{Binding Title}" />
			</Grid>

			<RichTextBox
				Grid.Row="1"
				Background="Transparent"
				BorderThickness="0" />
		</Grid>
	</Border>
</Window>
