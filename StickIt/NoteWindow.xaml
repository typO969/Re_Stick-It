<Window
	x:Class="StickIt.NoteWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	Width="400"
	Height="400"
	MinWidth="400"
	MinHeight="400"
	MaxWidth="400"
	MaxHeight="400"
	AllowsTransparency="True"
	Background="Transparent"
	ResizeMode="NoResize"
	UseLayoutRounding="False"
	WindowStyle="None">

	<Window.ContextMenu>
		<ContextMenu>
			<MenuItem Header="Color">
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Neon Pink"
					Tag="NeonPink" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Mulberry"
					Tag="Mulberry" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Fireball Fuchsia"
					Tag="FireballFuchsia" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Poppy"
					Tag="Poppy" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Saffron"
					Tag="Saffron" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Curry"
					Tag="Curry" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="3M Yellow"
					Tag="ThreeMYellow" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Canary Yellow"
					Tag="CanaryYellow" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Neon Green"
					Tag="NeonGreen" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Asparagus"
					Tag="Asparagus" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Emerald"
					Tag="Emerald" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Mediterranean Blue"
					Tag="MediterraneanBlue" />
			</MenuItem>
		</ContextMenu>
	</Window.ContextMenu>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="25" />
			<RowDefinition Height="25" />
			<RowDefinition Height="350" />
		</Grid.RowDefinitions>

		<!--  Title Bar  -->
		<Border
			x:Name="ControlBar"
			Grid.Row="0"
			HorizontalAlignment="Stretch"
			VerticalAlignment="Stretch"
			Background="{Binding PaperBrush}"
			CornerRadius="1.25"
			Effect="{DynamicResource DropShadow}">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
					<Button
						x:Name="btnClose"
						Width="15"
						Height="15"
						Margin="20,0,0,0"
						Background="{Binding PaperBrush}"
						BorderBrush="#FF6B5E08"
						Click="btnClose_Click"
						Content=""
						FontSize="8"
						Foreground="{Binding Background, ElementName=btnClose}" />
				</StackPanel>

				<StackPanel
					Grid.Column="1"
					Margin="0,0,20,0"
					HorizontalAlignment="Right"
					Orientation="Horizontal">

					<Button
						x:Name="btnMinimize"
						Width="15"
						Height="15"
						Margin="0"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Background="{Binding PaperBrush}"
						BorderBrush="#FF5A4E00"
						Click="btnMinimize_Click"
						Content="&#xE75D;"
						FontFamily="Segoe MDL2 Assets"
						FontSize="9"
						Foreground="{Binding Background, ElementName=btnMinimize}" />
				</StackPanel>
			</Grid>
		</Border>

		<!--  Note Title  -->
		<TextBox
			x:Name="txtNoteTitle"
			Grid.Row="1"
			Width="400"
			Height="25"
			MinWidth="400"
			MinHeight="25"
			MaxWidth="400"
			MaxHeight="25"
			HorizontalContentAlignment="Center"
			Background="{Binding PaperBrush}"
			BorderBrush="{Binding PaperBrush}"
			FontFamily="Helvetica"
			FontSize="18"
			FontWeight="Bold"
			GotFocus="txtNoteTitle_GotFocus"
			HorizontalScrollBarVisibility="Disabled"
			LostFocus="txtNoteTitle_LostFocus"
			MaxLines="1"
			Text="{Binding Title}"
			VerticalScrollBarVisibility="Disabled" />

		<!--  Main Content Area  -->
		<RichTextBox
			x:Name="txtNoteContent"
			Grid.Row="2"
			Width="400"
			Height="350"
			Background="{Binding PaperBrush}"
			BorderBrush="{Binding PaperBrush}"
			GotFocus="txtNoteContent_GotFocus"
			HorizontalScrollBarVisibility="Disabled"
			LostFocus="txtNoteContent_LostFocus"
			MouseDown="Note_MouseDown"
			RenderTransformOrigin="0.5,0.5"
			VerticalScrollBarVisibility="Disabled" />
	</Grid>
</Window>
