<Window
	x:Class="StickIt.NoteWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:conv="clr-namespace:StickIt.Converters"
	Width="400"
	Height="400"
	MinWidth="400"
	MinHeight="400"
	MaxWidth="400"
	MaxHeight="400"
	AllowsTransparency="True"
	Background="Transparent"
	ResizeMode="NoResize"
	UseLayoutRounding="False"
	WindowStyle="None">

	<Window.Resources>
		<conv:NoteComponentBrushConverter x:Key="NoteComponentBrush" />

		<Style x:Key="NoteIconButton" TargetType="Button">
			<Setter Property="Width" Value="16" />
			<Setter Property="Height" Value="16" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="FontSize" Value="8" />
			<Setter Property="Background" Value="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}" />
			<Setter Property="BorderBrush" Value="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Buttons}" />
			<Setter Property="Foreground" Value="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Text}" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border
							x:Name="bd"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="1">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="bd" Property="Opacity" Value="0.95" />
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="bd" Property="Opacity" Value="0.80" />
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter TargetName="bd" Property="Opacity" Value="0.45" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</Window.Resources>

	<Window.ContextMenu>
		<ContextMenu>
			<MenuItem Header="Color">
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Neon Pink"
					Tag="NeonPink" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Mulberry"
					Tag="Mulberry" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Fireball Fuchsia"
					Tag="FireballFuchsia" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Poppy"
					Tag="Poppy" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Saffron"
					Tag="Saffron" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Curry"
					Tag="Curry" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="3M Yellow"
					Tag="ThreeMYellow" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Canary Yellow"
					Tag="CanaryYellow" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Neon Green"
					Tag="NeonGreen" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Asparagus"
					Tag="Asparagus" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Emerald"
					Tag="Emerald" />
				<MenuItem
					Click="ColorMenuItem_Click"
					Header="Mediterranean Blue"
					Tag="MediterraneanBlue" />
			</MenuItem>
		</ContextMenu>
	</Window.ContextMenu>

	<Border
		Padding="0"
		Background="{Binding PaperBrush}"
		BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Buttons}"
		BorderThickness="1"
		CornerRadius="1">

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="25" />
				<RowDefinition Height="25" />
				<RowDefinition Height="350" />
			</Grid.RowDefinitions>

			<!--  Control Bar  -->
			<Border
				x:Name="ControlBar"
				Grid.Row="0"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Stretch"
				Background="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=ControlBar}">

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<StackPanel HorizontalAlignment="Left" Orientation="Horizontal">

						<Button
							x:Name="btnClose"
							Margin="20,0,0,0"
							Click="btnClose_Click"
							Content=""
							Style="{StaticResource NoteIconButton}"
							ToolTip="Close">

							<Button.Template>
								<ControlTemplate TargetType="Button">

									<Border
										Background="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}"
										BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Buttons}"
										BorderThickness="1"
										CornerRadius="2"
										Opacity="0.80">

										<Border
											Margin="1"
											BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Highlights}"
											BorderThickness="1"
											CornerRadius="1"
											Opacity="0.2">

											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
										</Border>

									</Border>

								</ControlTemplate>
							</Button.Template>
						</Button>

					</StackPanel>

					<StackPanel
						Grid.Column="1"
						Margin="0,0,20,0"
						HorizontalAlignment="Right"
						Orientation="Horizontal">

						<!--  left,right,top.bottom  -->
						<Button
							x:Name="btnPin"
							Margin="0,0,2,0"
							Click="btnPinCycle_Click"
							Content="📌"
							Style="{StaticResource NoteIconButton}"
							ToolTip="Pin">

							<Button.Template>
								<ControlTemplate TargetType="Button">

									<Border
										Background="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}"
										BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Buttons}"
										BorderThickness="1"
										CornerRadius="2"
										Opacity="0.80">

										<Border
											Margin="1"
											BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Highlights}"
											BorderThickness="1"
											CornerRadius="1"
											Opacity="0.25">

											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
										</Border>

									</Border>

								</ControlTemplate>
							</Button.Template>
						</Button>

						<Button
							x:Name="btnMinimize"
							Click="btnMinimize_Click"
							Content="&#xE75D;"
							FontFamily="Segoe MDL2 Assets"
							Style="{StaticResource NoteIconButton}"
							ToolTip="Minimize">

							<Button.Template>
								<ControlTemplate TargetType="Button">

									<Border
										Background="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}"
										BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Buttons}"
										BorderThickness="1"
										CornerRadius="2"
										Opacity="0.80">

										<Border
											Margin="1"
											BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Highlights}"
											BorderThickness="1"
											CornerRadius="1"
											Opacity="0.25">

											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
										</Border>

									</Border>

								</ControlTemplate>
							</Button.Template>
						</Button>

					</StackPanel>
				</Grid>
			</Border>

			<!--  Note Title  -->
			<TextBox
				x:Name="txtNoteTitle"
				Grid.Row="1"
				Width="400"
				Height="25"
				MinWidth="400"
				MinHeight="25"
				MaxWidth="400"
				MaxHeight="25"
				HorizontalContentAlignment="Center"
				Background="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}"
				BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}"
				BorderThickness="0"
				FontFamily="Helvetica"
				FontSize="19"
				FontWeight="Bold"
				Foreground="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Text}"
				HorizontalScrollBarVisibility="Disabled"
				MaxLines="1"
				Text="{Binding Title}"
				VerticalScrollBarVisibility="Disabled" />

			<!--  Main Content Area  -->
			<RichTextBox
				x:Name="txtNoteContent"
				Grid.Row="2"
				Width="400"
				Height="350"
				Background="{Binding PaperBrush}"
				BorderBrush="{Binding PaperBrush}"
				BorderThickness="0"
				FontFamily="{Binding FontFamily}"
				FontSize="{Binding FontSize}"
				FontWeight="Normal"
				Foreground="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Text}"
				HorizontalScrollBarVisibility="Disabled"
				RenderTransformOrigin="0.5,0.5"
				VerticalScrollBarVisibility="Disabled" />
		</Grid>
	</Border>
</Window>
