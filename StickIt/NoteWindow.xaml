<Window
	x:Class="StickIt.NoteWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:conv="clr-namespace:StickIt.Converters"
	Width="400"
	Height="400"
	MinWidth="400"
	MinHeight="400"
	MaxWidth="400"
	MaxHeight="400"
	AllowsTransparency="True"
	Background="Transparent"
	ResizeMode="NoResize"
	UseLayoutRounding="False"
	WindowStyle="None">

	<Window.Resources>
		<conv:NoteComponentBrushConverter x:Key="NoteComponentBrush" />

		<Style x:Key="NoteIconButton" TargetType="Button">
			<Setter Property="Width" Value="16" />
			<Setter Property="Height" Value="16" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="FontSize" Value="8" />
			<Setter Property="Background" Value="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}" />
			<Setter Property="BorderBrush" Value="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Buttons}" />
			<Setter Property="Foreground" Value="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Text}" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border
							x:Name="bd"
							Background="{TemplateBinding Background}"
							BorderBrush="{TemplateBinding BorderBrush}"
							BorderThickness="{TemplateBinding BorderThickness}"
							CornerRadius="1">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="bd" Property="Opacity" Value="0.95" />
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="bd" Property="Opacity" Value="0.80" />
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter TargetName="bd" Property="Opacity" Value="0.45" />
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<DataTemplate x:Key="ColorSwatchIconTemplate">
			<Border
				Width="12"
				Height="12"
				Background="{Binding}"
				BorderBrush="#66000000"
				BorderThickness="1"
				CornerRadius="2" />
		</DataTemplate>

		<conv:ColorKeyToBackgroundBrushConverter x:Key="ColorKeyToBgBrush" />

	</Window.Resources>



	<Border
		Padding="0"
		Background="{Binding PaperBrush}"
		BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Buttons}"
		BorderThickness="1"
		CornerRadius="1">

		<Border.ContextMenu>
			<ContextMenu Opened="NoteMenu_Opened">

				<!--  Lifecycle  -->
				<MenuItem
					Click="Menu_NewNote"
					Header="Add note"
					InputGestureText="Ctrl+N" />
				<MenuItem
					Click="Menu_Delete"
					Header="Delete note"
					InputGestureText="Ctrl+W" />

				<Separator />

				<!--  Color  -->
				<MenuItem
					x:Name="miNoteColors"
					Header="Note colors"
					SubmenuOpened="NoteColors_SubmenuOpened">

					<MenuItem
						x:Name="NeonPinkMenuItem"
						Click="Menu_Color"
						Header="Neon Pink"
						Tag="NeonPink">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#dc39e5"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="MulberryMenuItem"
						Click="Menu_Color"
						Header="Mulberry"
						Tag="Mulberry">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#974F70"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="FireballFuchsiaMenuItem"
						Click="Menu_Color"
						Header="Fireball Fuchsia"
						Tag="FireballFuchsia">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#DD4B99"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="PoppyMenuItem"
						Click="Menu_Color"
						Header="Poppy"
						Tag="Poppy">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#C67D4D"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="SaffronMenuItem"
						Click="Menu_Color"
						Header="Saffron"
						Tag="Saffron">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#CB5147"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="CurryMenuItem"
						Click="Menu_Color"
						Header="Curry"
						Tag="Curry">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#F0B555"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="ThreeMYellowMenuItem"
						Click="Menu_Color"
						Header="3M Yellow (Default)"
						Tag="ThreeMYellow">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#F7E03D"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="CanaryYellowMenuItem"
						Click="Menu_Color"
						Header="Canary Yellow"
						Tag="CanaryYellow">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#F9F8BC"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="NeonGreenMenuItem"
						Click="Menu_Color"
						Header="Neon Green"
						Tag="NeonGreen">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#A6FC41"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="AsparagusMenuItem"
						Click="Menu_Color"
						Header="Asparagus"
						Tag="Asparagus">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#809840"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="EmeraldMenuItem"
						Click="Menu_Color"
						Header="Emerald"
						Tag="Emerald">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#62BDB8"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
					<MenuItem
						x:Name="MediterraneanBlueMenuItem"
						Click="Menu_Color"
						Header="Mediterranean Blue"
						Tag="MediterraneanBlue">
						<MenuItem.Icon>
							<Border
								Width="12"
								Height="12"
								Background="#4077C4"
								BorderBrush="#66000000"
								BorderThickness="1"
								CornerRadius="2" />
						</MenuItem.Icon>
					</MenuItem>
				</MenuItem>

				<!--  Font  -->
				<MenuItem
					Click="Menu_FontSettings"
					Header="Font settings..."
					IsEnabled="False" />

				<!--  Properties  -->
				<MenuItem Header="Note properties">
					<!--  These are populated on open  -->
					<MenuItem
						x:Name="miProp_Id"
						Header="Note ID:"
						IsEnabled="False" />
					<MenuItem
						x:Name="miProp_Contains"
						Header="Contains:"
						IsEnabled="False" />
					<MenuItem
						x:Name="miProp_Created"
						Header="Created:"
						IsEnabled="False" />
					<MenuItem
						x:Name="miProp_Modified"
						Header="Modified:"
						IsEnabled="False" />
					<Separator />
					<MenuItem
						x:Name="miProp_Position"
						Header="Position:"
						IsEnabled="False" />
					<MenuItem
						x:Name="miProp_Color"
						Header="Color:"
						IsEnabled="False" />
					<MenuItem
						x:Name="miProp_Sticky"
						Header="Sticky:"
						IsEnabled="False" />
					<MenuItem
						x:Name="miProp_Font"
						Header="Font:"
						IsEnabled="False" />
				</MenuItem>

				<Separator />

				<!--  Editing  -->
				<MenuItem Click="Menu_Cut" Header="Cut" />
				<MenuItem Click="Menu_Copy" Header="Copy" />
				<MenuItem Click="Menu_Paste" Header="Paste" />

				<Separator />

				<!--  Save/Load (note: you already autosave, but keep these for parity)  -->
				<MenuItem Click="Menu_SaveNow" Header="Save notes now" />
				<MenuItem
					Click="Menu_LoadNotes"
					Header="Load notes..."
					IsEnabled="False" />

				<Separator />

				<!--  Window state  -->
				<MenuItem
					Click="Menu_Minimize"
					Header="Minimize"
					InputGestureText="Ctrl+M" />
				<MenuItem Click="Menu_Restore" Header="Restore" />
				<MenuItem Click="Menu_MinimizeAll" Header="Minimize all notes" />
				<MenuItem Click="Menu_RestoreAll" Header="Restore hidden notes" />

				<Separator />

				<!--  Sticky  -->
				<MenuItem Header="Sticky mode">
					<MenuItem
						Click="Menu_Sticky"
						Header="Not stuck"
						Tag="0" />
					<MenuItem
						Click="Menu_Sticky"
						Header="Always on top"
						Tag="1" />
					<MenuItem Header="Stick to application (future)" IsEnabled="False" />
				</MenuItem>

				<Separator />

				<!--  App-level  -->
				<MenuItem
					Click="Menu_Preferences"
					Header="Preferences..."
					IsEnabled="False" />
				<MenuItem
					Click="Menu_NoteManager"
					Header="Note manager..."
					IsEnabled="False" />

				<Separator />

				<!--  Debug parity  -->
				<MenuItem Click="Menu_Debug" Header="Properties (debug)" />

				<Separator />

				<MenuItem Click="Menu_Exit" Header="Quit StickIt" />
			</ContextMenu>
		</Border.ContextMenu>


		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="25" />
				<RowDefinition Height="25" />
				<RowDefinition Height="350" />
			</Grid.RowDefinitions>

			<!--  Control Bar  -->
			<Border
				x:Name="ControlBar"
				Grid.Row="0"
				HorizontalAlignment="Stretch"
				VerticalAlignment="Stretch"
				Background="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=ControlBar}">

				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<StackPanel HorizontalAlignment="Left" Orientation="Horizontal">

						<Button
							x:Name="btnClose"
							Margin="20,0,0,0"
							Click="btnClose_Click"
							Content=""
							Style="{StaticResource NoteIconButton}"
							ToolTip="Close">

							<Button.Template>
								<ControlTemplate TargetType="Button">

									<Border
										Background="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}"
										BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Buttons}"
										BorderThickness="1"
										CornerRadius="2"
										Opacity="0.80">

										<Border
											Margin="1"
											BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Highlights}"
											BorderThickness="1"
											CornerRadius="1"
											Opacity="0.2">

											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
										</Border>

									</Border>

								</ControlTemplate>
							</Button.Template>
						</Button>

					</StackPanel>

					<StackPanel
						Grid.Column="1"
						Margin="0,0,20,0"
						HorizontalAlignment="Right"
						Orientation="Horizontal">

						<!--  left,right,top.bottom  -->
						<Button
							x:Name="btnPin"
							Margin="0,0,2,0"
							Click="btnPinCycle_Click"
							Content="📌"
							Style="{StaticResource NoteIconButton}"
							ToolTip="Pin">

							<Button.Template>
								<ControlTemplate TargetType="Button">

									<Border
										Background="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}"
										BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Buttons}"
										BorderThickness="1"
										CornerRadius="2"
										Opacity="0.80">

										<Border
											Margin="1"
											BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Highlights}"
											BorderThickness="1"
											CornerRadius="1"
											Opacity="0.25">

											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
										</Border>

									</Border>

								</ControlTemplate>
							</Button.Template>
						</Button>

						<Button
							x:Name="btnMinimize"
							Click="btnMinimize_Click"
							Content="&#xE75D;"
							FontFamily="Segoe MDL2 Assets"
							Style="{StaticResource NoteIconButton}"
							ToolTip="Minimize">

							<Button.Template>
								<ControlTemplate TargetType="Button">

									<Border
										Background="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}"
										BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Buttons}"
										BorderThickness="1"
										CornerRadius="2"
										Opacity="0.80">

										<Border
											Margin="1"
											BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Highlights}"
											BorderThickness="1"
											CornerRadius="1"
											Opacity="0.25">

											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
										</Border>

									</Border>

								</ControlTemplate>
							</Button.Template>
						</Button>

					</StackPanel>
				</Grid>
			</Border>

			<!--  Note Title  -->
			<TextBox
				x:Name="txtNoteTitle"
				Grid.Row="1"
				Width="400"
				Height="25"
				MinWidth="400"
				MinHeight="25"
				MaxWidth="400"
				MaxHeight="25"
				HorizontalContentAlignment="Center"
				Background="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}"
				BorderBrush="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Background}"
				BorderThickness="0"
				FontFamily="Helvetica"
				FontSize="19"
				FontWeight="Bold"
				Foreground="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Text}"
				HorizontalScrollBarVisibility="Disabled"
				MaxLines="1"
				MouseLeftButtonDown="txtNoteTitle_select"
				PreviewMouseLeftButtonDown="txtNoteTitle_select"
				Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
				VerticalScrollBarVisibility="Disabled" />

			<!--  Main Content Area  -->
			<RichTextBox
				x:Name="txtNoteContent"
				Grid.Row="2"
				Width="400"
				Height="350"
				Background="{Binding PaperBrush}"
				BorderBrush="{Binding PaperBrush}"
				BorderThickness="0"
				ContextMenu="{x:Null}"
				FontFamily="{Binding FontFamily}"
				FontSize="{Binding FontSize}"
				FontWeight="Normal"
				Foreground="{Binding ColorKey, Converter={StaticResource NoteComponentBrush}, ConverterParameter=Text}"
				HorizontalScrollBarVisibility="Disabled"
				RenderTransformOrigin="0.5,0.5"
				VerticalScrollBarVisibility="Disabled" />
		</Grid>
	</Border>
</Window>
